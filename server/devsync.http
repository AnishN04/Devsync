###############################################
# AUTH
###############################################

### 1. Health Check
GET http://localhost:5000/api/health

###

### 2. Register User
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Super Admin",
  "email": "sadmin@devsync.com",
  "password": "admin123",
  "role": "Admin"
}

###

### 3. Login (copy accessToken → paste into @token above)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "sadmin@devsync.com",
  "password": "admin123"
}

###

### 4. Refresh Access Token
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiaWF0IjoxNzcyNjg5NTM0LCJleHAiOjE3NzMyOTQzMzR9.XD-lmrXKX-xQdHfrNNJo6Lu0B3zyRy4bnhw55y7Q79Q"
}

###

### 5. Logout
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "refreshToken": "PASTE_REFRESH_TOKEN_HERE"
}

###############################################
# PROJECTS
###############################################

### 6. Get All Projects
GET {{baseUrl}}/projects
Authorization: Bearer {{token}}

###

### 7. Create Project
POST {{baseUrl}}/projects
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "DevSync MVP",
  "description": "My first DevSync project"
}

###

### 8. Get Project by ID
GET {{baseUrl}}/projects/1
Authorization: Bearer {{token}}

###

### 9. Update Project
PUT {{baseUrl}}/projects/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "DevSync MVP v2",
  "description": "Updated description"
}

###

### 10. Delete Project (Admin only)
DELETE {{baseUrl}}/projects/1
Authorization: Bearer {{token}}

###############################################
# TASKS
###############################################

### 11. Get Tasks (by project)
GET {{baseUrl}}/tasks?projectId=1
Authorization: Bearer {{token}}

###

### 12. Create Task
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "projectId": 1,
  "title": "Build Kanban board UI",
  "description": "Drag-and-drop board with columns",
  "priority": "High",
  "status": "Todo"
}

###

### 13. Update Task
PUT {{baseUrl}}/tasks/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "In Progress",
  "priority": "High"
}

###

### 14. Delete Task (Admin/Manager only)
DELETE {{baseUrl}}/tasks/1
Authorization: Bearer {{token}}

###############################################
# MEMBERS
###############################################

### 15. Get Project Members
GET {{baseUrl}}/members/1
Authorization: Bearer {{token}}

###

### 16. Add Member to Project
POST {{baseUrl}}/members/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "userId": 2,
  "role": "Developer"
}

###

### 17. Remove Member from Project
DELETE {{baseUrl}}/members/1/2
Authorization: Bearer {{token}}

###############################################
# AI (requires GEMINI_API_KEY in .env)
###############################################

### 18. AI Task Suggestions
POST {{baseUrl}}/ai/suggest
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Implement user authentication with OAuth and JWT tokens"
}
